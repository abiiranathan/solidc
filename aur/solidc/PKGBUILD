# Contributor: Dr. Abiira Nathan <nabiira2by2@gmail.com>

pkgname=solidc
pkgver=1.10.1
pkgrel=1
pkgdesc="A robust C library for data structures, concurrency, and utilities."
arch=('x86_64' 'aarch64')
url="https://github.com/abiiranathan/solidc"
license=('MIT')
depends=()
makedepends=('cmake' 'git' 'make' 'gcc')
provides=('solidc')
conflicts=('solidc')
source=("${pkgname}-${pkgver}.tar.gz::https://github.com/abiiranathan/${pkgname}/archive/refs/tags/v${pkgver}.tar.gz")
b2sums=('SKIP')

build() {
  cd "${pkgname}-${pkgver}"
  cmake -B build \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_INSTALL_PREFIX=/usr \
    -DBUILD_TESTS=ON \
    -DBUILD_BENCHMARKS=OFF \
    -DBUILD_SHARED_LIBS=OFF
  cmake --build build
}

package() {
  cd "${pkgname}-${pkgver}"
  DESTDIR="${pkgdir}" cmake --install build
}

# Run the tests after building but before packaging
check() {
  cd "${pkgname}-${pkgver}"
  ctest --test-dir build --output-on-failure
}